# search process
function psg {
    local pat=$1
    [[ -z $pat ]] && {
        echo "usage: psg <process-name-or-pattern>"
        return 1
    }

    local -a pids
    pids=($(pgrep -f "$pat")) || {
        echo "no process matched: $pat"
        return 1
    }

    ps -fp $pids
}

