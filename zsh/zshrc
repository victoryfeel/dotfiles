# ==================== Functions ====================
# tm to start a tmuxsession
function tm {
    if [ -z "$1" ]; then
        tmux attach || tmux new-session
    else
        tmux attach -t "$1" || tmux new-session -s "$1"
    fi
}
# vim and automatically tmux
function v {
    if [ -n "$TMUX" ]; then
        nvim "$@"
    else
        tmux new-session -A -s edit nvim "$@"
    fi
}
# ctrl+g to open lazygit
function lazygit_widget {
    lazygit
    zle reset-prompt
}
zle -N lazygit_widget
bindkey '^g' lazygit_widget
# ctrl+f to search
fzf-work-edit() {
  local file=$(fd --type f --hidden --exclude .git . ~/alexmak/ | fzf --height 40% --reverse)
    if [ -n "$file" ]; then
      zle -I
      cd "$(dirname "$file")"
      nvim "$file"
    fi
    zle reset-prompt
}
zle -N fzf-work-edit
bindkey '^k' fzf-work-edit


