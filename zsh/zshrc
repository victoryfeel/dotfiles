# ==================== Functions ====================
# 使用tm创建tmuxsession
function tm {
    if [ -z "$1" ]; then
        tmux attach || tmux new-session
    else
        tmux attach -t "$1" || tmux new-session -s "$1"
    fi
}
# vim and automatically tmux
function v {
    if [ -n "$TMUX" ]; then
        nvim "$@"
    else
        tmux new-session -A -s edit nvim "$@"
    fi
}
# ctrl+g打开lazygit
